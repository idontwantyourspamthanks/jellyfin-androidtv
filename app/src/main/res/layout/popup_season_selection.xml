<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/season_selection_panel_bg"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/seasonSelectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.02"
        android:text="@string/lbl_jump_to_season"
        android:textColor="@android:color/white"
        android:textSize="22sp" />

    <View
        android:layout_width="48dp"
        android:layout_height="3dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/season_selection_accent" />

    <androidx.leanback.widget.HorizontalGridView
        android:id="@+id/seasonSelectionGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:clipToPadding="false" />
</LinearLayout>
